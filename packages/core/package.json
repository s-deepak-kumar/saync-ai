{
  "name": "@saync/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core for Saync — contract types, expectation registry, and flow definitions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "saync",
    "testing",
    "verification",
    "contracts",
    "expectations"
  ],
  "author": "S Deepak Kumar <dipkfilms@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/s-deepak-kumar/saync-ai#readme",
  "bugs": {
    "url": "https://github.com/s-deepak-kumar/saync-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-deepak-kumar/saync-ai.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
