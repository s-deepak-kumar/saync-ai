{
  "name": "@saync/agent",
  "version": "0.1.0",
  "description": "Playwright-based verification agent for Saync",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "saync-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["playwright", "testing", "verification"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@saync/core": "workspace:*",
    "@saync/backend": "workspace:*",
    "playwright": "^1.44.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}