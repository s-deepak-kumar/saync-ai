{
  "name": "@saync/react",
  "version": "0.1.0",
  "description": "React SDK for Saync — declare expectations on Button, Input, Form, Image, Link, and 30+ other components.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "saync",
    "react",
    "testing",
    "verification",
    "contracts",
    "qa"
  ],
  "author": "S Deepak Kumar <dipkfilms@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/s-deepak-kumar/saync-ai#readme",
  "bugs": {
    "url": "https://github.com/s-deepak-kumar/saync-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-deepak-kumar/saync-ai.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@saync/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
