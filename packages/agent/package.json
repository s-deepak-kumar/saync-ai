{
  "name": "@saync/agent",
  "version": "0.1.0",
  "description": "Playwright-based verification agent for Saync. Drives every contract + flow declared by the SDK and POSTs results to the local Saync server.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "saync-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "saync",
    "playwright",
    "testing",
    "verification",
    "contracts",
    "qa",
    "agent"
  ],
  "author": "S Deepak Kumar <dipkfilms@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/s-deepak-kumar/saync-ai#readme",
  "bugs": {
    "url": "https://github.com/s-deepak-kumar/saync-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-deepak-kumar/saync-ai.git",
    "directory": "packages/agent"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@saync/core": "workspace:*",
    "playwright": "^1.44.0",
    "chalk": "^5.3.0",
    "jiti": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
